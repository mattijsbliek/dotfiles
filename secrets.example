# Secrets — copy to ~/.secrets and configure for this machine.
# This file uses bash syntax and is sourced by both bash and fish.
# It is git-ignored.
#
# === 1Password Service Account (recommended for servers) ===
# Each server has its own vault, its own tokens, and its own service account.
#
# export OP_SERVICE_ACCOUNT_TOKEN="ops_..."
# export GITHUB_TOKEN=$(op read "op://Server-Name/GitHub Token/credential" 2>/dev/null)
#
# === On macOS (uses 1Password app, no service account needed) ===
# export GITHUB_TOKEN=$(op read "op://Personal/GitHub Token/credential" 2>/dev/null)
#
# === Hardcoded fallback ===
# export GITHUB_TOKEN="your-github-token-here"
